# freelancer-tax-helper .env.example (Cycle 117·외부 발사 준비)
# PO 결정 시 즉시 활성·헌법 §3 정합 (env only·하드코딩 X)

# === Anthropic API (옵션·LLM 영수증 OCR) ===
ANTHROPIC_API_KEY=sk-ant-...
LLM_OPT_IN=false  # true 시 영수증 OCR LLM 활성·BYOK

# === PortOne v2 (한국 PG·결제 활성 시) ===
PORTONE_API_KEY=
PORTONE_SECRET_KEY=
PORTONE_WEBHOOK_SECRET=
PORTONE_SANDBOX=true  # production 시 false

# === Resend (이메일·환영·영수증·갱신 알림) ===
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@<your-domain>
EMAIL_FROM_NAME=freelancer-tax-helper
EMAIL_REPLY_TO=support@<your-domain>

# === Better Auth (인증·옵션) ===
AUTH_SECRET_KEY=  # 32+ bit·secrets.token_urlsafe(32)
AUTH_SANDBOX=true

# === 사업자 정보 (사업자 등록 후 .env에) ===
BIZ_NAME=
BIZ_REGISTRATION_NUMBER=  # 홈택스 사업자등록번호
BIZ_ADDRESS=
BIZ_CONTACT_EMAIL=
BIZ_PHONE=
BIZ_REPRESENTATIVE=

# === Streamlit Cloud (배포 시 secrets.toml 추가) ===
# https://share.streamlit.io · Settings → Secrets → 위 변수 복사
